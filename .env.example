# Your Anthropic API key — used as the shared "host" key for visitors until
# they hit the per-visitor limit below. Server-side only, never sent to clients.
ANTHROPIC_API_KEY=

# How many brand-new words a single visitor may generate with the HOST key
# before being asked to supply their own. Cached words never count. Default: 10.
# HOST_WORD_LIMIT=10

# Set when running behind a reverse proxy (Fly/Render/nginx/...) so per-IP
# limits see the real client IP via X-Forwarded-For. E.g. "1" to trust one hop.
# Leave unset locally so clients can't spoof the header.
# TRUST_PROXY=1

# PORT=3000
