# Your Anthropic API key — used as the shared "host" key for visitors until
# they hit the per-visitor limit below. Server-side only, never sent to clients.
ANTHROPIC_API_KEY=

# How many brand-new words a single visitor may generate with the HOST key
# before being asked to supply their own. Cached words never count. Default: 10.
# HOST_WORD_LIMIT=10

# Secret code a visitor can type into the API-key box to lift their host limit
# (keeps using the host key, no cap). If unset, this feature is disabled. Kept
# out of source so it isn't visible in the public repo.
# UNLOCK_CODE=changeme

# Token for the maintenance endpoints (GET /api/admin/words to list the shared
# store, POST /api/admin/words/delete to prune it). If unset, those endpoints
# return 404. Use a long random value; send it as the x-admin-token header.
# ADMIN_TOKEN=a-long-random-string

# Set when running behind a reverse proxy (Fly/Render/nginx/...) so per-IP
# limits see the real client IP via X-Forwarded-For. E.g. "1" to trust one hop.
# Leave unset locally so clients can't spoof the header.
# TRUST_PROXY=1

# PORT=3000
